import re

def extract_nodes_and_volumes(inp_file, output_file):
    with open(inp_file, 'r') as f:
        lines = f.readlines()
    
    nodes = []
    volumes = []
    inside_node_section = False
    current_volume = None
    
    for line in lines:
        if "*NODE" in line.upper():
            inside_node_section = True
            nodes.append("*NODE")  # Add *NODE at the top
            continue
        elif inside_node_section and line.strip().startswith("*"):
            inside_node_section = False
        
        if inside_node_section:
            nodes.append(line.strip())
            continue
        
        match = re.match(r'\*ELEMENT, type=C3D4, ELSET=(\S+)', line.strip(), re.IGNORECASE)
        if match:
            if current_volume:
                volumes.append("\n".join(current_volume))
            current_volume = [line.strip()]  # Start new volume section
            continue
        elif current_volume and line.strip().startswith("*"):
            volumes.append("\n".join(current_volume))
            current_volume = None
            continue
        
        if current_volume:
            current_volume.append(line.strip())
    
    if current_volume:
        volumes.append("\n".join(current_volume))
    
    with open(output_file, 'w') as f:
        f.write("\n".join(nodes) + "\n" + "\n".join(volumes))
    
    print(f"Nodes and volumes extracted and saved to {output_file}")

# Example usage
extract_nodes_and_volumes("gmsh.inp", "mesh_output.inp")
